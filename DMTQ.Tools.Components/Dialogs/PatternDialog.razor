@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using DMTQ.Tools.Core.Models
@using DMTQ.Tools.Core.Models.Entity
@using DMTQ.Tools.Core.Models.Export
@using DMTQ.Tools.Core.Models.Project
@implements IDialogContentComponent<SongPattern>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="12" Style="min-width: 360px;">

    <FluentGrid Spacing="3">
        <FluentGridItem xs="12" sm="6">
            <FluentNumberField @bind-Value="Content.PatternId" Label="Pattern ID *"
                             Disabled="@(originalId is not null)" Required />
        </FluentGridItem>
        <FluentGridItem xs="12" sm="6">
            <FluentNumberField @bind-Value="Content.Line" Label="Line" Placeholder="2Line/3Line/4Line" />
        </FluentGridItem>
        <FluentGridItem xs="12" sm="6">
            <FluentNumberField @bind-Value="Content.Signature" Label="Difficulty" Placeholder="0/1/2/3" />
        </FluentGridItem>
        <FluentGridItem xs="12" sm="6">
            <FluentNumberField @bind-Value="Content.Difficulty" Label="Stars" />
        </FluentGridItem>
        <FluentGridItem xs="12" sm="6">
            <FluentNumberField @bind-Value="Content.PointType" Label="Point Type" />
        </FluentGridItem>
        <FluentGridItem xs="12" sm="6">
            <FluentNumberField @bind-Value="Content.PointValue" Label="Point Value" />
        </FluentGridItem>
        <FluentGridItem xs="12" sm="6">
            <FluentTextField @bind-Value="Content.Name" Label="Pattern Name" />
        </FluentGridItem>
        <FluentGridItem xs="12">
            <FluentSwitch @bind-Value="flgChecked" Label="Enable" />
        </FluentGridItem>
    </FluentGrid>

</FluentStack>

@code {
    [Parameter] public SongPattern Content { get; set; } = default!;
    [CascadingParameter] public FluentDialog Dialog { get; set; } = default!;

    private int? originalId;

    private bool flgChecked
    {
        get => Content.Flg == "Y";
        set => Content.Flg = value ? "Y" : "N";
    }

    protected override void OnInitialized()
    {
        if (Content.PatternId > 0)
            originalId = Content.PatternId;
    }
}
