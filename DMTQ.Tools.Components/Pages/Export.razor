@page "/export"
@inject IProjectState State
@inject IProjectWorkflow Workflow
@inject PackageQaService QaService

<h1>Export</h1>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16" Style="margin-bottom: 1.25rem;">
    <FluentSelect Items="@(new[] { "android", "ios" })"
                  OptionText="@(i => i)"
                  OptionValue="@(i => i)"
                  @bind-SelectedOption="State.SelectedExportPlatform"
                  Label="Platform" />

    <FluentSelect Items="@(new[] { "Keep", "CompressAll", "UncompressAll" })"
                  OptionText="@(i => i)"
                  OptionValue="@(i => i)"
                  @bind-SelectedOption="State.ExportCompressionMode"
                  Label="Compression policy" />

    <FluentTextField @bind-Value="exportRoot"
                     Label="Output directory"
                     Placeholder="D:\DMTQExports\android"
                     Style="width: 100%" />
    <FluentButton Appearance="Appearance.Accent"
                  @onclick="ExportPlatformPackage"
                  Disabled="@(!State.HasPackage || isBusy)">
        Export
    </FluentButton>

    @if (!State.HasPackage)
    {
        <div class="status-message">Import a package before exporting.</div>
    }

    @if (qaSummary is not null)
    {
        <div class="qa-summary @(qaSummary.IsClean ? "success" : qaSummary.HasErrors ? "error" : "warning")">
            <strong>Pre-export QA:</strong> @qaSummary.Summary
            @if (qaSummary.HasErrors)
            {
                <span> — Fix errors before exporting.</span>
            }
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="status-message">@message</div>
    }
</FluentStack>

@if (State.LastPlatformExportResult is not null)
{
    <FluentGrid Spacing="3" AdaptiveRendering="true">
        <FluentGridItem xs="12" sm="6" md="4">
            <FluentCard>
                <span class="metric-label">Platform</span>
                <strong>@State.LastPlatformExportResult.Platform</strong>
            </FluentCard>
        </FluentGridItem>
        <FluentGridItem xs="12" sm="6" md="4">
            <FluentCard>
                <span class="metric-label">Manifest entries</span>
                <strong>@State.LastPlatformExportResult.ManifestEntryCount</strong>
            </FluentCard>
        </FluentGridItem>
        <FluentGridItem xs="12" sm="6" md="4">
            <FluentCard>
                <span class="metric-label">Files written</span>
                <strong>@State.LastPlatformExportResult.FilesWritten</strong>
            </FluentCard>
        </FluentGridItem>
        <FluentGridItem xs="12" sm="6" md="4">
            <FluentCard>
                <span class="metric-label">Skipped baseline</span>
                <strong>@State.LastPlatformExportResult.FilesSkippedAsBaseline</strong>
            </FluentCard>
        </FluentGridItem>
        <FluentGridItem xs="12" sm="6" md="4">
            <FluentCard>
                <span class="metric-label">Missing current files</span>
                <strong>@State.LastPlatformExportResult.MissingCurrentFiles</strong>
            </FluentCard>
        </FluentGridItem>
        <FluentGridItem xs="12" sm="6" md="4">
            <FluentCard>
                <span class="metric-label">Validation</span>
                <strong>@ValidationText</strong>
            </FluentCard>
        </FluentGridItem>
    </FluentGrid>
}

@if (State.LastValidationResult is not null && !State.LastValidationResult.IsValid)
{
    <section class="toolbar-panel">
        <h2>Validation errors</h2>
        <ul class="diagnostic-list">
            @foreach (var error in State.LastValidationResult.Errors.Take(100))
            {
                <li>@error</li>
            }
        </ul>
    </section>
}

@code {
    private string exportRoot = string.Empty;
    private string? message;
    private bool isBusy;
    private QaReport? qaSummary;

    private string ValidationText => State.LastValidationResult is null
        ? "Not run"
        : State.LastValidationResult.IsValid ? "Passed" : $"{State.LastValidationResult.Errors.Count} errors";

    private async Task ExportPlatformPackage()
    {
        isBusy = true;
        message = "Running QA...";
        try
        {
            if (State.CurrentPackage is not null)
            {
                qaSummary = QaService.Run(State.CurrentPackage);
                if (qaSummary.HasErrors)
                {
                    message = $"QA found {qaSummary.ErrorCount} error(s). Fix them before exporting.";
                    State.Diagnostics.Add($"Pre-export QA: {qaSummary.Summary}");
                    return;
                }
            }

            message = "Exporting platform package...";
            await Workflow.ExportPlatformPackageAsync(
                exportRoot,
                State.SelectedExportPlatform,
                State.PlatformExportMode);
            message = State.LastPlatformExportResult?.Validation.IsValid == true
                ? "Platform export completed and validation passed."
                : "Platform export completed with validation errors.";
        }
        catch (Exception ex)
        {
            message = ex.Message;
            State.Diagnostics.Add("Platform export error: " + ex.Message);
        }
        finally
        {
            isBusy = false;
        }
    }
}
